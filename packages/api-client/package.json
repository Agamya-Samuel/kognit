    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "tsup": "^8.2.3",
    "eslint": "^8.57.0"
  }
}
