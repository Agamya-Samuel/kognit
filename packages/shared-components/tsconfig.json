{
  "extends": "../config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "lib": ["es2022", "dom", "dom.iterable"],
    "incremental": false,
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@edutech/ui": ["../ui/src"],
      "@edutech/validation": ["../validation/src"],
      "@edutech/api-client": ["../api-client/src"],
      "@edutech/types": ["../types/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
