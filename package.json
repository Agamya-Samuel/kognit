{
  "name": "edutech-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "EduTech Platform - Monorepo with Next.js apps and NestJS API",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test --watch",
    "test:coverage": "turbo run test:coverage",
    "test:api:cov": "turbo run test:coverage --filter=api",
    "test:web-student:cov": "turbo run test:coverage --filter=web-student",
    "test:web-instructor:cov": "turbo run test:coverage --filter=web-instructor",
    "test:web-admin:cov": "turbo run test:coverage --filter=web-admin",
    "test:web-landing:cov": "turbo run test:coverage --filter=web-landing",
    "audit:high": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "lighthouse": "lhci autorun",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@testing-library/dom": "^10.4.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.14.1",
  "overrides": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@livekit/components-react": {
      "react": "^19.2.6",
      "react-dom": "^19.2.6"
    }
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "drizzle-orm": "^0.45.2"
  }
}
