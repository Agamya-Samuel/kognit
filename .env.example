# ============================================
# SHARED ENVIRONMENT VARIABLES
# ============================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/edutech

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production

# Email (AWS SES)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
EMAIL_FROM=noreply@eduplatform.com

# ============================================
# API (apps/api)
# ============================================

# Node Environment
NODE_ENV=development
PORT=3001

# API Configuration
API_URL=http://localhost:3001
API_NAME=edutech-api

# Mux (Video Processing)
MUX_TOKEN_ID=your-mux-token-id
MUX_SECRET_KEY=your-mux-secret-key
MUX_WEBHOOK_SIGNING_SECRET=your-mux-webhook-secret

# AWS S3 (File Storage)
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=edutech-uploads
AWS_S3_ACCESS_KEY_ID=your-aws-access-key
AWS_S3_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_CLOUDFRONT_DOMAIN=cdn.eduplatform.com

# Razorpay (Payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# LiveKit (Real-time Video)
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://livekit.eduplatform.com

# PostHog (Analytics)
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_HOST=https://app.posthog.com

# Sentry (Error Monitoring)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# ============================================
# WEB-STUDENT APP (apps/web-student)
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=EduTech Student Portal

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-public-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your-sentry-public-dsn

# OAuth (Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth (GitHub)
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# WEB-INSTRUCTOR APP (apps/web-instructor)
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=EduTech Instructor Portal

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-public-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your-sentry-public-dsn

# OAuth (Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth (GitHub)
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# WEB-ADMIN APP (apps/web-admin)
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=EduTech Admin Portal

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-public-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your-sentry-public-dsn

# ============================================
# DOCTORP DEPLOYMENT CONFIGURATION
# ============================================

# API Deployment
DOKPLOY_API_DOMAIN=api.eduplatform.com
DOKPLOY_API_PORT=3001

# Web-Student Deployment
DOKPLOY_WEB_STUDENT_DOMAIN=student.eduplatform.com
DOKPLOY_WEB_STUDENT_PORT=3000

# Web-Instructor Deployment
DOKPLOY_WEB_INSTRUCTOR_DOMAIN=instructor.eduplatform.com
DOKPLOY_WEB_INSTRUCTOR_PORT=3002

# Web-Admin Deployment
DOKPLOY_WEB_ADMIN_DOMAIN=admin.eduplatform.com
DOKPLOY_WEB_ADMIN_PORT=3003
