# ── Application ──────────────────────────────────────────────────
# Runtime mode. Controls Swagger docs, CSRF cookie `secure` flag,
# Sentry sample rates, exception details in responses.
NODE_ENV=development

# HTTP listen port.
PORT=3000

# Pino log level (fatal | error | warn | info | debug | trace).
LOG_LEVEL=info

# ── CORS / Frontends ─────────────────────────────────────────────
# Required. Comma-separated list of allowed origins for CORS, OAuth
# callback validation, and Socket.IO gateways.
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3000

# Student portal base URL (used for email links).
STUDENT_APP_URL=http://localhost:3001

# Instructor portal base URL (used for email links).
INSTRUCTOR_APP_URL=http://localhost:3002

# ── Database ─────────────────────────────────────────────────────
# Required. Full Postgres connection string used at runtime by
# Drizzle/postgres-js. Throws at startup if unset.
DATABASE_URL=postgresql://edutech:edutech_password@localhost:5432/edutech

# Individual connection params used by drizzle-kit CLI only.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=edutech
DATABASE_PASSWORD=edutech_password
DATABASE_NAME=edutech
DATABASE_SSL=false

# ── Redis ────────────────────────────────────────────────────────
# Used for cache, BullMQ queues, and the Socket.IO adapter.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT (Required) ───────────────────────────────────────────────
# Required. HS256 secret for access-token signing. Min 32 chars.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-32-plus-char-random-string-xxxxxxxxxxxxxxx
JWT_EXPIRY=15m

# Required. HS256 secret for refresh-token signing. Min 32 chars.
JWT_REFRESH_SECRET=change-me-to-a-32-plus-char-random-string-xxxxxxxxxxxxxxx
JWT_REFRESH_EXPIRY=30d

# ── AWS S3 ───────────────────────────────────────────────────────
# File uploads + LiveKit recording egress. All optional, but uploads
# will not work without AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=edutech-uploads
AWS_S3_CDN_URL=
# Override S3 endpoint (e.g. for non-AWS S3-compatible stores used by
# LiveKit egress). Not in the Zod schema — read at runtime.
AWS_S3_ENDPOINT=

# ── Mux (video processing) ───────────────────────────────────────
# Optional. All Mux features disable if MUX_TOKEN_ID is missing.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
# Signing key for signed playback URLs (HS256 JWT). Runtime-only.
MUX_SIGNING_KEY=

# ── LiveKit (live classes) ───────────────────────────────────────
# Optional. Live classes disable if LIVEKIT_API_KEY is missing.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# ── Razorpay (payments) ──────────────────────────────────────────
# Optional. Payments disable if RAZORPAY_KEY_ID is missing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── PostHog (analytics) ──────────────────────────────────────────
# Optional. Analytics disable if POSTHOG_API_KEY is missing.
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── OAuth ────────────────────────────────────────────────────────
# Google OAuth 2.0. Optional — login with Google disables if
# GOOGLE_CLIENT_ID is missing.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# GitHub OAuth. Declared but not yet wired to a strategy.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# ── Email ────────────────────────────────────────────────────────
# Selects provider at runtime: `ses` (default) or `resend`.
EMAIL_PROVIDER=ses

# SMTP fallback (reserved — no SMTP provider currently wired).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=EduTech Platform

# AWS SES (used when EMAIL_PROVIDER=ses).
SES_SOURCE_EMAIL=

# Resend (used when EMAIL_PROVIDER=resend).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── SMS ──────────────────────────────────────────────────────────
# Selects provider at runtime: `sns` (default) or `twilio`.
SMS_PROVIDER=sns

# AWS SNS (used when SMS_PROVIDER=sns).
SNS_SMS_SENDER_ID=

# Twilio (used when SMS_PROVIDER=twilio).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Rate Limiting ────────────────────────────────────────────────
# Throttler window in seconds and max requests per window.
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ── Monitoring ───────────────────────────────────────────────────
# Sentry DSN. If unset, Sentry init is skipped.
SENTRY_DSN=
