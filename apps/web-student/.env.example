# ── API ──────────────────────────────────────────────────────────
# Base URL of the NestJS API (must be reachable by the browser).
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ── Public URL ───────────────────────────────────────────────────
# The public-facing domain used for SEO metadata (OpenGraph, Twitter
# cards) and certificate share links. Defaults to localhost:3004 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3004

# ── Analytics (optional) ────────────────────────────────────────
# PostHog project key (leave empty to disable client-side analytics).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
